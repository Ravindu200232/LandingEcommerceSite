{
  "family": "landingecommercesite-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/REPOSITORY:COMMIT_SHA",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "MONGODB_URI",
          "valueFrom": "AWS_SECRETS_MANAGER_ARN:MONGODB_URI::"
        },
        {
          "name": "BETTER_AUTH_SECRET",
          "valueFrom": "AWS_SECRETS_MANAGER_ARN:BETTER_AUTH_SECRET::"
        }
      ]
    }
  ]
}
